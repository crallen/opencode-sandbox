#!/usr/bin/env bash
#
# opencode-sandbox — run OpenCode in an isolated Docker container with a
# custom agent suite. Any project directory can be mounted as the workspace.
#
# Usage:
#   opencode-sandbox [options] [workspace-path] [-- opencode-args...]
#
# Options:
#   -r, --ref DIR          Mount DIR as a read-only reference directory (repeatable)
#   -k, --key FILE         SSH private key to mount for git/cargo authentication.
#                          Defaults to ~/.ssh/id_ed25519 or ~/.ssh/id_rsa (whichever
#                          exists). Ignored on Linux where agent forwarding is used.
#   -V, --volume-preset P  Mount named Docker volumes for build artifact directories,
#                          bypassing the slow gRPC FUSE workspace mount. (repeatable)
#                          Available presets:
#                            node  — /workspace/node_modules (workspace-scoped)
#                            rust  — /workspace/target (workspace-scoped)
#                                    + shared Cargo registry and git cache
#                            go    — shared GOPATH (/root/go)
#   --clean                Remove workspace-scoped volumes for the current workspace
#                          (i.e. those created by -V node and -V rust), then exit.
#                          Shared volumes (Cargo registry, GOPATH) are not removed.
#   --host-network         Use the host's network stack (--network host). Allows the
#                          container to reach services bound to localhost on the host
#                          (e.g. a local database). Linux only — has no effect on
#                          macOS or Windows where Docker runs inside a VM.
#   --build                Build the Docker image locally from source
#   --pull                 Pull latest image from GHCR; or refresh base image when
#                          combined with --build
#   -h, --help             Show this help message
#
# If workspace-path is omitted, the current directory is used.
# Everything after "--" is forwarded to the opencode binary inside the container.
#
# API keys are read from the calling environment:
#   ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY, etc.
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

# Image pulled from GHCR on the default (no --build) path
GHCR_IMAGE="ghcr.io/crallen/opencode-sandbox:latest"

# Image name used when building locally (--build path)
LOCAL_IMAGE="opencode-sandbox"

CONTAINER_PREFIX="opencode-sandbox"

# Resolve the repo root (where this script lives is bin/, go one level up).
# Use readlink -f to resolve symlinks so this works when the script is
# symlinked into a directory on PATH (e.g. ~/.local/bin/).
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

usage() {
    sed -n '/^# Usage:/,/^#$/p' "$0" | sed 's/^# \?//'
    echo
    echo "Examples:"
    echo "  opencode-sandbox                                    # workspace = cwd"
    echo "  opencode-sandbox ~/projects/myapp                   # explicit workspace"
    echo "  opencode-sandbox -r ~/projects/lib-a .              # with a reference dir"
    echo "  opencode-sandbox -r ../lib-a -r ../lib-b ~/myapp    # multiple references"
    echo "  opencode-sandbox -k ~/.ssh/my_key ~/projects/myapp  # explicit SSH key"
    echo "  opencode-sandbox -V node ~/projects/myapp           # fast node_modules volume"
    echo "  opencode-sandbox -V rust -V node ~/projects/myapp   # multiple presets"
    echo "  opencode-sandbox --clean ~/projects/myapp           # remove workspace volumes"
    echo "  opencode-sandbox --host-network ~/projects/myapp   # reach host-side databases (Linux)"
    echo "  opencode-sandbox --pull .                           # update to latest GHCR image"
    echo "  opencode-sandbox --build .                          # build locally from source"
    echo "  opencode-sandbox . -- --version                     # pass flags to opencode"
    exit 0
}

die() {
    echo "error: $1" >&2
    exit 1
}

info() {
    echo "==> $1"
}

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------

FORCE_BUILD=false
FORCE_PULL=false
CLEAN_VOLUMES=false
HOST_NETWORK=false
WORKSPACE=""
REF_DIRS=()
VOLUME_PRESETS=()
OPENCODE_ARGS=()
SSH_KEY=""

# Valid preset names
_VALID_PRESETS=(node rust go)

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--ref)
            [[ $# -ge 2 ]] || die "--ref requires a directory argument"
            REF_DIRS+=("$2")
            shift 2
            ;;
        -k|--key)
            [[ $# -ge 2 ]] || die "--key requires a file argument"
            SSH_KEY="$2"
            shift 2
            ;;
        -V|--volume-preset)
            [[ $# -ge 2 ]] || die "--volume-preset requires a preset name argument"
            preset="$2"
            valid=false
            for p in "${_VALID_PRESETS[@]}"; do
                [[ "$preset" == "$p" ]] && valid=true && break
            done
            "$valid" || die "unknown volume preset: '${preset}' (valid: ${_VALID_PRESETS[*]})"
            VOLUME_PRESETS+=("$preset")
            shift 2
            ;;
        --clean)
            CLEAN_VOLUMES=true
            shift
            ;;
        --host-network)
            HOST_NETWORK=true
            shift
            ;;
        --build)
            FORCE_BUILD=true
            shift
            ;;
        --pull)
            FORCE_PULL=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        --)
            shift
            OPENCODE_ARGS=("$@")
            break
            ;;
        -*)
            die "unknown option: $1 (use -- to pass flags to opencode)"
            ;;
        *)
            if [[ -z "$WORKSPACE" ]]; then
                WORKSPACE="$1"
            else
                die "unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

# Default workspace to current directory
WORKSPACE="${WORKSPACE:-.}"

# Resolve to absolute path
WORKSPACE="$(cd "$WORKSPACE" 2>/dev/null && pwd)" || die "workspace path does not exist: $WORKSPACE"

# Derive workspace name early so --clean can use it without going further.
# (The full volume-flag assembly block below also uses this value.)
# Sanitize to Docker's allowed charset: [a-zA-Z0-9_.-], must start alphanum.
WORKSPACE_NAME="$(basename "$WORKSPACE" | tr -c 'a-zA-Z0-9_.-' '-' | sed 's/^[^a-zA-Z0-9]/x/; s/-*$//')"

# ---------------------------------------------------------------------------
# --clean: remove workspace-scoped volumes, then exit.
# Must run before image resolution so we don't hit the registry unnecessarily.
# Shared volumes (cargo registry/git, gopath) are intentionally left intact.
# ---------------------------------------------------------------------------

if [[ "$CLEAN_VOLUMES" == true ]]; then
    _scoped_volumes=(
        "opencode-node-modules-${WORKSPACE_NAME}"
        "opencode-rust-target-${WORKSPACE_NAME}"
        "opencode-data-${WORKSPACE_NAME}"
    )
    _removed=()
    _missing=()
    for vol in "${_scoped_volumes[@]}"; do
        if docker volume inspect "$vol" &>/dev/null; then
            docker volume rm "$vol" >/dev/null
            _removed+=("$vol")
        else
            _missing+=("$vol")
        fi
    done
    if [[ ${#_removed[@]} -gt 0 ]]; then
        info "Removed volumes: ${_removed[*]}"
    fi
    if [[ ${#_missing[@]} -gt 0 ]]; then
        info "Already absent:  ${_missing[*]}"
    fi
    exit 0
fi

# ---------------------------------------------------------------------------
# Validate reference directories (detect basename collisions early)
# ---------------------------------------------------------------------------

if [[ ${#REF_DIRS[@]} -gt 0 ]]; then
    declare -A _REF_NAMES
    for ref in "${REF_DIRS[@]}"; do
        ref_abs="$(cd "$ref" 2>/dev/null && pwd)" || die "reference path does not exist: $ref"
        ref_name="$(basename "$ref_abs")"
        if [[ -n "${_REF_NAMES[$ref_name]:-}" ]]; then
            die "reference name collision: '${ref_name}' is used by both '${_REF_NAMES[$ref_name]}' and '${ref_abs}'. Rename one of the directories to avoid ambiguity."
        fi
        _REF_NAMES[$ref_name]="$ref_abs"
    done
    unset _REF_NAMES
fi

# ---------------------------------------------------------------------------
# Resolve the image to run
# ---------------------------------------------------------------------------

build_image() {
    info "Building ${LOCAL_IMAGE} image..."
    local build_args=(
        -t "$LOCAL_IMAGE"
        -f "${REPO_ROOT}/build/Dockerfile"
    )
    if [[ "$FORCE_PULL" == true ]]; then
        build_args+=(--pull)
    fi
    docker build "${build_args[@]}" "$REPO_ROOT"
}

pull_image() {
    local remote_digest local_digest

    # Compute the remote manifest digest. For multi-arch OCI image indexes the
    # --format '{{.Manifest.Digest}}' template silently falls back to the full
    # pretty-printed output, so we hash the raw manifest bytes ourselves — this
    # is exactly how registries compute digests per the OCI spec.
    remote_digest="$(docker buildx imagetools inspect "$GHCR_IMAGE" --raw 2>/dev/null \
        | sha256sum | awk '{print "sha256:"$1}')"

    if [[ -z "$remote_digest" ]]; then
        # Registry unreachable — fall back to local if it exists, else let
        # docker pull fail with a meaningful error message.
        if docker image inspect "$GHCR_IMAGE" &>/dev/null; then
            info "Could not reach registry, using cached image"
            return
        fi
        info "Pulling ${GHCR_IMAGE}..."
        docker pull "$GHCR_IMAGE"
        return
    fi

    # Retrieve the local image digest. The `|| true` guard prevents `set -e`
    # from killing the script when the image is not cached locally (docker
    # image inspect exits non-zero and pipefail propagates the failure).
    local_digest="$(docker image inspect "$GHCR_IMAGE" \
        --format '{{index .RepoDigests 0}}' 2>/dev/null | cut -d@ -f2 || true)"

    if [[ -n "$local_digest" && "$local_digest" == "$remote_digest" ]]; then
        info "Already up to date (${remote_digest})"
        return
    fi

    info "Pulling ${GHCR_IMAGE}..."
    docker pull "$GHCR_IMAGE"
}

if [[ "$FORCE_BUILD" == true ]]; then
    build_image
    RUN_IMAGE="$LOCAL_IMAGE"
elif [[ "$FORCE_PULL" == true ]] || ! docker image inspect "$GHCR_IMAGE" &>/dev/null; then
    pull_image
    RUN_IMAGE="$GHCR_IMAGE"
else
    RUN_IMAGE="$GHCR_IMAGE"
fi

# ---------------------------------------------------------------------------
# Collect API keys from the environment (written to a temp file so they
# don't appear in the host process listing via `ps`)
# ---------------------------------------------------------------------------

ENV_FILE="$(mktemp)"
trap 'rm -f "$ENV_FILE"' EXIT
chmod 600 "$ENV_FILE"

# Pass host UID/GID so the entrypoint can remap the container user at runtime
echo "HOST_UID=$(id -u)" >> "$ENV_FILE"
echo "HOST_GID=$(id -g)" >> "$ENV_FILE"

# Well-known LLM provider keys — pass through any that are set
for var in \
    ANTHROPIC_API_KEY \
    OPENAI_API_KEY \
    GOOGLE_API_KEY \
    GEMINI_API_KEY \
    MISTRAL_API_KEY \
    GROQ_API_KEY \
    XAI_API_KEY \
    DEEPSEEK_API_KEY \
    OPENROUTER_API_KEY \
    TOGETHER_API_KEY \
    AWS_ACCESS_KEY_ID \
    AWS_SECRET_ACCESS_KEY \
    AWS_SESSION_TOKEN \
    AWS_REGION \
    AZURE_OPENAI_API_KEY \
    AZURE_OPENAI_ENDPOINT \
; do
    if [[ -n "${!var:-}" ]]; then
        echo "${var}=${!var}" >> "$ENV_FILE"
    fi
done

# ---------------------------------------------------------------------------
# Assemble docker flags, volume mounts, and ssh forwarding
# ---------------------------------------------------------------------------

# Initialize flag arrays early so both the SSH block and the run block can
# append to them during assembly.
DOCKER_FLAGS=(--rm --interactive)
if [[ -t 0 ]]; then
    DOCKER_FLAGS+=(--tty)
fi
if [[ "$HOST_NETWORK" == true ]]; then
    DOCKER_FLAGS+=(--network host)
fi

VOLUME_FLAGS=()

# Workspace (read-write)
VOLUME_FLAGS+=(-v "${WORKSPACE}:/workspace:rw")

# Host git config (read-only, optional)
if [[ -f "${HOME}/.gitconfig" ]]; then
    VOLUME_FLAGS+=(-v "${HOME}/.gitconfig:/home/opencode/.gitconfig:ro")
fi

# Host SSH agent forwarding.
#
# On macOS, Docker Desktop runs containers in a Linux VM. Unix domain sockets
# in /private/tmp are owned by the macOS kernel and cannot be relayed into
# the VM — the socket file appears inside the container but the agent process
# is unreachable, so every connection attempt gets ECONNREFUSED.
#
# Instead of mounting the whole ~/.ssh directory (which brings in a config
# file that may contain macOS-specific directives the Linux ssh binary
# rejects), we mount only the specific key file(s) needed for SSH auth.
# The entrypoint sets GIT_SSH_COMMAND to invoke ssh with an explicit -i flag
# pointing at the mounted key, bypassing ~/.ssh/config entirely.
#
# Fallback chain:
#   1. Direct agent socket bind-mount — Linux hosts only
#   2. Specific key file mount        — macOS hosts, or when no agent socket
#   3. Nothing                        — no SSH auth available; git over SSH fails
if [[ "$(uname -s)" == "Linux" && -n "${SSH_AUTH_SOCK:-}" && -S "$SSH_AUTH_SOCK" ]]; then
    # Linux host: socket is in the same kernel namespace — bind-mount works.
    # Read-write required: Unix sockets need write access to connect.
    VOLUME_FLAGS+=(-v "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:rw")
    echo "SSH_AUTH_SOCK=/tmp/ssh-agent.sock" >> "$ENV_FILE"
else
    # macOS host (or no agent socket): mount a specific key file read-only.
    # Explicit --key takes priority; otherwise try id_ed25519 then id_rsa.
    if [[ -n "$SSH_KEY" ]]; then
        _keyfile="$(cd "$(dirname "$SSH_KEY")" && pwd)/$(basename "$SSH_KEY")"
        [[ -f "$_keyfile" ]] || die "SSH key not found: ${SSH_KEY}"
    else
        _keyfile=""
        for _candidate in "${HOME}/.ssh/id_ed25519" "${HOME}/.ssh/id_rsa"; do
            if [[ -f "$_candidate" ]]; then
                _keyfile="$_candidate"
                break
            fi
        done
    fi

    if [[ -n "$_keyfile" ]]; then
        VOLUME_FLAGS+=(-v "${_keyfile}:/home/opencode/.ssh/id:ro")
        [[ -f "${_keyfile}.pub" ]] && \
            VOLUME_FLAGS+=(-v "${_keyfile}.pub:/home/opencode/.ssh/id.pub:ro")
        echo "SSH_IDENTITY_FILE=/home/opencode/.ssh/id" >> "$ENV_FILE"
    else
        info "WARNING: No SSH key found. SSH-based git operations will fail."
        info "         Use -k/--key to specify a key, or create ~/.ssh/id_ed25519 or ~/.ssh/id_rsa."
    fi
    unset _keyfile _candidate
fi

# Persistent config volume (tui.json, opencode.json user edits)
# Must be mounted BEFORE the subdirectory bind-mounts so they overlay on top.
VOLUME_FLAGS+=(-v "opencode-config:/home/opencode/.config/opencode")

# Global agents, skills, commands from this repo (read-only)
# These bind-mounts overlay specific subdirectories inside the config volume.
VOLUME_FLAGS+=(-v "${REPO_ROOT}/.opencode/agents:/home/opencode/.config/opencode/agents:ro")
VOLUME_FLAGS+=(-v "${REPO_ROOT}/.opencode/skills:/home/opencode/.config/opencode/skills:ro")
VOLUME_FLAGS+=(-v "${REPO_ROOT}/.opencode/commands:/home/opencode/.config/opencode/commands:ro")

# Reference directories (read-only)
for ref in "${REF_DIRS[@]+"${REF_DIRS[@]}"}"; do
    ref_abs="$(cd "$ref" 2>/dev/null && pwd)" || die "reference path does not exist: $ref"
    ref_name="$(basename "$ref_abs")"
    VOLUME_FLAGS+=(-v "${ref_abs}:/reference/${ref_name}:ro")
done

# ---------------------------------------------------------------------------
# Assemble remaining volume flags now that WORKSPACE_NAME is set
# ---------------------------------------------------------------------------

# Persistent state volume (theme, model selection, prompt history)
VOLUME_FLAGS+=(-v "opencode-state:/home/opencode/.local/state/opencode")

# Persistent data volume (sessions, snapshots, logs — scoped per workspace to
# avoid SQLite WAL contention and session bleed between unrelated projects)
VOLUME_FLAGS+=(-v "opencode-data-${WORKSPACE_NAME}:/home/opencode/.local/share/opencode")

# ---------------------------------------------------------------------------
# Volume presets — named Docker volumes that bypass the grpcfuse workspace
# mount for high-churn build artifact directories.
#
# Workspace-scoped volumes (node_modules, target) are named with the
# workspace slug so each project gets its own isolated volume.
#
# Shared volumes (Cargo registry/git, GOPATH) are reused across all
# workspaces so downloaded dependencies are cached globally.
# ---------------------------------------------------------------------------

for preset in "${VOLUME_PRESETS[@]+"${VOLUME_PRESETS[@]}"}"; do
    case "$preset" in
        node)
            VOLUME_FLAGS+=(-v "opencode-node-modules-${WORKSPACE_NAME}:/workspace/node_modules")
            ;;
        rust)
            VOLUME_FLAGS+=(-v "opencode-rust-target-${WORKSPACE_NAME}:/workspace/target")
            VOLUME_FLAGS+=(-v "opencode-cargo-registry:/root/.cargo/registry")
            VOLUME_FLAGS+=(-v "opencode-cargo-git:/root/.cargo/git")
            ;;
        go)
            VOLUME_FLAGS+=(-v "opencode-gopath:/root/go")
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

# Append the shell PID to guarantee uniqueness across concurrent invocations.
if [[ -z "$WORKSPACE_NAME" || "$WORKSPACE_NAME" == "$CONTAINER_PREFIX" ]]; then
    CONTAINER_NAME="${CONTAINER_PREFIX}-$$"
else
    CONTAINER_NAME="${CONTAINER_PREFIX}-${WORKSPACE_NAME}-$$"
fi

info "Workspace: ${WORKSPACE}"
for ref in "${REF_DIRS[@]+"${REF_DIRS[@]}"}"; do
    ref_abs="$(cd "$ref" 2>/dev/null && pwd)"
    info "Reference: ${ref_abs} -> /reference/$(basename "$ref_abs")"
done
if [[ ${#VOLUME_PRESETS[@]} -gt 0 ]]; then
    info "Presets:   ${VOLUME_PRESETS[*]}"
fi
if [[ "$HOST_NETWORK" == true ]]; then
    info "Network:   host"
fi
info "Container: ${CONTAINER_NAME}"

# no-new-privileges prevents privilege escalation via setuid binaries during
# execve. The entrypoint needs CHOWN/FOWNER/DAC_OVERRIDE to fix file ownership
# and SETUID/SETGID for gosu to DROP from root to the opencode user (which uses
# direct setuid()/setgid() syscalls and is always permitted under no-new-privs).
exec docker run \
    "${DOCKER_FLAGS[@]}" \
    --name "$CONTAINER_NAME" \
    --security-opt no-new-privileges \
    --cap-drop ALL \
    --cap-add CHOWN \
    --cap-add DAC_OVERRIDE \
    --cap-add FOWNER \
    --cap-add SETUID \
    --cap-add SETGID \
    --env-file "$ENV_FILE" \
    "${VOLUME_FLAGS[@]}" \
    "$RUN_IMAGE" \
    "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"
